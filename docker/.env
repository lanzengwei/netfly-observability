# 业务项目 Metrics 地址（Prometheus 抓取目标）
METRICS_TARGET_HOST=192.168.32.50
METRICS_TARGET_PORT=9771

# Grafana / Prometheus 中显示的项目名（与业务 .env 中 OBSERVABILITY_PROJECT 保持一致）
OBSERVABILITY_PROJECT=skeleton

# Loki Push API（业务项目 OBSERVABILITY_LOG_DRIVER=loki 时使用此地址）
LOKI_PUSH_URL=http://192.168.32.50:3100/loki/api/v1/push
